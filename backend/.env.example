APP_NAME=Influencer Trends API
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/influencer
DEFAULT_SOURCE=seed
APIFY_TOKEN=
TIKTOK_APIFY_ACTOR=
INSTAGRAM_APIFY_ACTOR=
TIKTOK_QUERY=viral videos
INSTAGRAM_QUERY=reels trends
YT_DLP_COMMAND=yt-dlp
YT_DLP_FORMAT=bv*+ba/b
YT_DLP_MERGE_FORMAT=mp4
YT_DLP_COOKIES_FILE=
DOWNLOAD_TIMEOUT_SEC=900
DB_FALLBACK_TO_SQLITE=true
APIFY_FALLBACK_TO_SEED=false
APIFY_OVERFETCH_MULTIPLIER=1
APIFY_MAX_SELECTOR_TERMS=3
