APP_NAME=Influencer Trends API
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/influencer
DEFAULT_SOURCE=tiktok_custom
APIFY_TOKEN=
TIKTOK_APIFY_ACTOR=
INSTAGRAM_APIFY_ACTOR=
TIKTOK_QUERY=healthy lifestyle
TIKTOK_MS_TOKENS=
TIKTOK_CUSTOM_HEADLESS=true
TIKTOK_CUSTOM_SESSIONS=1
TIKTOK_CUSTOM_SLEEP_AFTER=3
TIKTOK_CUSTOM_BROWSER=chromium
INSTAGRAM_QUERY=reels trends
INSTAGRAM_CUSTOM_USERNAME=
INSTAGRAM_CUSTOM_PASSWORD=
INSTAGRAM_CUSTOM_SESSION_FILE=
INSTAGRAM_CUSTOM_MAX_POSTS_PER_TAG=120
X_API_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com
X_API_SEARCH_PAGES=4
YT_DLP_COMMAND=yt-dlp
YT_DLP_FORMAT=bv*+ba/b
YT_DLP_MERGE_FORMAT=mp4
YT_DLP_COOKIES_FILE=
DOWNLOAD_TIMEOUT_SEC=900
DB_FALLBACK_TO_SQLITE=true
APIFY_FALLBACK_TO_SEED=false
APIFY_OVERFETCH_MULTIPLIER=1
APIFY_COST_OPTIMIZED=true
APIFY_MAX_SELECTOR_TERMS=1
APIFY_REQUEST_RETRIES=4
APIFY_RETRY_BACKOFF_SEC=1.5
APIFY_RETRY_MAX_BACKOFF_SEC=12
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
